# === LLM (chat) — 用于 agent 推理 ===
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === Embeddings — 与 chat 可用不同 provider（KB 向量化）===
# 不配则复用 OPENAI_*。常见 provider：
#   - OpenAI:        https://api.openai.com/v1
#   - DMXAPI:        https://www.dmxapi.cn
#   - 阿里 DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
#   - 硅基流动:       https://api.siliconflow.cn/v1
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small

# === Web search (Tavily — LLM-optimized structured results) ===
# Get a free key at https://tavily.com (1000 calls/month free tier).
# Without a key, web_search falls back to DuckDuckGo HTML scraping which is
# often unreachable from corporate networks.
TAVILY_API_KEY=

# 路径（可选，相对项目根）
# KB_DIR=./kb
# SESSIONS_DIR=./sessions